# Creative Waco Tools — environment variables
# Copy to `.env.local` and fill in values. Do not reuse Tortoise & Hare Clerk keys.

# --- Clerk (Creative Waco account only) ---
# Create a new application at https://dashboard.clerk.com in the Creative Waco
# Clerk account — not the Tortoise & Hare account.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional overrides (defaults match app/layout.tsx and middleware.ts)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in/
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Creative Spark Dashboard (optional for other tools) ---
# GIVEBUTTER_API_KEY=
# GIVEBUTTER_ACCOUNT_ID=
# ASANA_ACCESS_TOKEN=
# ASANA_REFRESH_TOKEN=
