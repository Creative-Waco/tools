# Creative Waco Tools — environment variables
# Copy to `.env.local` and fill in values. Do not reuse Tortoise & Hare Clerk keys.

# --- Clerk (Creative Waco account only) ---
# Create a new application at https://dashboard.clerk.com in the Creative Waco
# Clerk account — not the Tortoise & Hare account.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Optional overrides (defaults match app/layout.tsx and middleware.ts)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in/
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Creative Spark Dashboard (optional for other tools) ---
# GIVEBUTTER_API_KEY=
# GIVEBUTTER_ACCOUNT_ID=
# ASANA_ACCESS_TOKEN=
# ASANA_REFRESH_TOKEN=

# --- Analytics Dashboard (GA4 + Search Console) ---
# creativewaco.org property ID (see ~/.config/creativewaco/ga4-property-id.txt)
# GA4_PROPERTY_ID=306499072
# Local dev: path to Creative Waco reader key (~/.config/creativewaco/ga4-service-account.json)
# GA4_SERVICE_ACCOUNT_PATH=/Users/you/.config/creativewaco/ga4-service-account.json
# Vercel production: paste full service account JSON
# GA4_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# --- Airtable (Campaign Builder) ---
# Personal access token with data.records:read/write and schema.bases:read/write
# AIRTABLE_API_KEY=pat...
# AIRTABLE_BASE_ID=app...
# Local dev: ~/.config/creativewaco/airtable-api-key.txt and airtable-base-id.txt
